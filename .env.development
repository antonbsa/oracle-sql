# Password for SYS, SYSTEM, and PDBADMIN accounts
ORACLE_PASSWORD=masterpass

# Custom pluggable database name. Leave unset to use the default XEPDB1.
# Setting this to XEPDB1 will break APP_USER creation — see README troubleshooting.
# ORACLE_DATABASE=DEVDB

# Application user (created automatically in ORACLE_DATABASE or XEPDB1 if unset)
APP_USER=app_user
APP_USER_PASSWORD=masterpass

# Host port to expose Oracle listener
ORACLE_PORT=1522
